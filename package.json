{
  "name": "@lifeforge/lifeforge--railway-map",
  "displayName": "Railway Map",
  "repository": {
    "type": "git",
    "url": "https://github.com/lifeforge-app/lifeforge-module-railwayMap.git"
  },
  "version": "0.0.5",
  "type": "module",
  "author": "Melvin Chia <melvinchia623600@gmail.com>",
  "description": "The ultimate map for MRT and LRT in Malaysia and Singapore",
  "scripts": {
    "typecheck": "pnpm run typecheck:client && pnpm run typecheck:server",
    "typecheck:client": "cd client && tsc",
    "typecheck:server": "cd server && tsc",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "cd server && vite build"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "i18n-iso-countries": "^7.14.0",
    "leaflet": "^1.9.4",
    "tinycolor2": "^1.6.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/leaflet": "^1.9.20"
  },
  "lifeforge": {
    "icon": "uil:subway",
    "category": "Lifestyle"
  },
  "peerDependencies": {
    "@lifeforge/api": "workspace:*",
    "@lifeforge/configs": "workspace:*",
    "@lifeforge/federation": "workspace:*",
    "@lifeforge/localization": "workspace:*",
    "@lifeforge/pocketbase": "workspace:*",
    "@lifeforge/server-utils": "workspace:*",
    "@lifeforge/ui": "workspace:*"
  }
}
